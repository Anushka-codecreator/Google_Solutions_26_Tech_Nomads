rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Need Entity Validation
    function isValidNeed(data) {
      return data.description is string && data.description.size() <= 2000
        && data.category in ['medical', 'food', 'water', 'infrastructure', 'education', 'other']
        && data.status in ['reported', 'analyzed', 'assigned', 'in-progress', 'resolved']
        && data.reportedAt is string
        && (data.priorityScore == null || data.priorityScore is number)
        && (data.severity == null || data.severity is string)
        && (data.reportedBy == null || data.reportedBy is string);
    }

    // Volunteer Entity Validation
    function isValidVolunteer(data) {
      return data.uid is string
        && data.name is string && data.name.size() <= 100
        && data.available is bool
        && (data.activeTasks == null || data.activeTasks is number)
        && (data.tasksCompleted == null || data.tasksCompleted is number);
    }

    // Needs Collection
    match /needs/{needId} {
      allow list: if true;
      allow get: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // Volunteers Collection
    match /volunteers/{volunteerId} {
      allow list: if true;
      allow get: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }
  }
}